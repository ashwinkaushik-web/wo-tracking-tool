# =====================================================================
# Streamlit Secrets — DO NOT COMMIT THE REAL VERSION
# =====================================================================
# Copy this file to .streamlit/secrets.toml and fill in real values.
# In Streamlit Community Cloud, paste these into the Secrets manager
# via the app dashboard instead of committing the file.
# =====================================================================

[snowflake]
user = "SVC_PC_LOOKUP_TOOL__PROD__USER"
account = "WEDSQVX-PATTERN"
role = "DATA_FANATICS_READ_ROLE"
warehouse = "PREDICT_BG_WH_LARGE"
database = "ANALYTICS_DB"
schema = "STG_AMACZAR"

# RSA private key (.p8 file contents). Paste the FULL key including
# the BEGIN and END lines. Indentation must stay flush left.
private_key = """-----BEGIN PRIVATE KEY-----
MIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...
... (paste your entire key here, all lines flush left) ...
...AbCdEf123==
-----END PRIVATE KEY-----
"""

# Only set this if the private key file is ENCRYPTED with a passphrase.
# If your .p8 file has no passphrase, leave this commented out.
# private_key_passphrase = "your-passphrase-here"
